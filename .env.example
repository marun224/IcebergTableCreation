# Copy to .env and adjust if needed. docker compose and the Python scripts both read it.

# --- MinIO / S3 credentials (also used as MinIO root user/password) ---
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1

# --- Storage ---
WAREHOUSE_BUCKET=warehouse

# --- Catalog metadata backend (Postgres) ---
# Persists Iceberg namespace/table registrations so they survive container restarts.
POSTGRES_USER=iceberg
POSTGRES_PASSWORD=iceberg
POSTGRES_DB=iceberg

# --- Endpoints (host-side; containers talk to each other over the compose network) ---
REST_URI=http://localhost:8181
S3_ENDPOINT=http://localhost:9100

# --- Iceberg identifiers ---
ICEBERG_NAMESPACE=nyc
ICEBERG_TABLE=yellow_tripdata

# --- Source data ---
INPUT_DIR=input_data
